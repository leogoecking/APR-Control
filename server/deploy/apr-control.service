[Unit]
Description=APR Control Server
After=network.target

[Service]
Type=simple
User=aprcontrol
WorkingDirectory=/opt/apr-control
Environment=APR_CONTROL_DATA_DIR=/var/lib/apr-control
ExecStart=/usr/bin/npm run start --workspace @apr-control/server
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
